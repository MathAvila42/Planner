# Copie para .env e preencha (nunca commitar o .env real).
# Estas mesmas três variáveis também precisam ser adicionadas em
# Vercel → Project Settings → Environment Variables.

# Project Settings → API → Project URL
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Project Settings → API → service_role key (secreta, nunca vai para o frontend)
SUPABASE_SERVICE_ROLE_KEY=

# String aleatória longa usada para assinar o cookie de sessão (JWT).
# Gere uma com: openssl rand -hex 32
SESSION_SECRET=

# Porta local do servidor (opcional, padrão 4000)
PORT=4000
